# Application
RPE_APP_NAME="דוח RPE קבוצתי"
RPE_APP_ENV=production
RPE_APP_VERSION=local

# Storage driver: local keeps the current localStorage behavior.
# Use supabase to load/save data through Supabase tables.
RPE_STORAGE_DRIVER=local
# Demo only: true seeds the fixed demo team.
# Real multi-team production: set this to false.
RPE_SEED_DEMO_DATA=false
RPE_TEAM_ID=00000000-0000-4000-8000-000000000001
RPE_TEAM_NAME="קבוצת דמו"

# Supabase public client config.
# These values are safe to expose in the browser when paired with proper RLS policies.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
# Server-side only. Required for Owner/Admin API actions such as creating coach Auth users
# and resetting passwords. Never expose this value in assets/env.js or browser code.
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SCHEMA=public
SUPABASE_TABLE_PREFIX=
